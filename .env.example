# Copy this file to .env and replace the dummy values.

DEVIN_ORG_ID=org_dummy_replace_me
DEVIN_API_KEY=cog_dummy_replace_me
DEVIN_API_BASE_URL=https://api.devin.ai
DEVIN_ENABLE_REAL_CALLS=false
DEVIN_MAX_ACU_LIMIT=2

# Optional for GitHub write-backs such as issue comments/status updates.
GITHUB_TOKEN=ghp_dummy_replace_me_optional
GITHUB_WEBHOOK_SECRET=replace_with_a_random_webhook_secret

SUPERSET_REPO=lukecode0/superset
SUPERSET_REPO_URL=https://github.com/lukecode0/superset
DEFAULT_ISSUE_NUMBER=3
DATABASE_PATH=opsbridge.db
